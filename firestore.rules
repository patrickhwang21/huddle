rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Registered user profiles. Only the owner can write their own doc;
    // any signed-in user can read (needed to show names/avatars elsewhere).
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Events are readable by anyone who has the event code/link, since
    // guests join without signing in. Only the creator can create/update/delete.
    match /events/{eventId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.creatorUid == request.auth.uid;
      allow update, delete: if request.auth != null
                    && request.auth.uid == resource.data.creatorUid;

      // Participant availability. Readable by anyone (guests included) so
      // the results/heatmap works without an account. Registered users can
      // only edit their own linked entry; guest entries (no linkedUid) are
      // intentionally left open, matching the lightweight guest-auth model
      // described in the app design (no server-verifiable guest password).
      match /participants/{participantId} {
        allow read: if true;
        allow create: if true;
        allow update: if resource.data.linkedUid == null
                       || (request.auth != null && request.auth.uid == resource.data.linkedUid);
        allow delete: if request.auth != null &&
                       (request.auth.uid == resource.data.linkedUid ||
                        request.auth.uid == get(/databases/$(database)/documents/events/$(eventId)).data.creatorUid);
      }
    }
  }
}
